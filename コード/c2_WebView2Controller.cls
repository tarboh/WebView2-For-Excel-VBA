Public Sub CloseWebView2()
    Dim hr As Long
    Dim result As Variant

    ' pController 偼 Environment::CreateCoreWebView2Controller
    ' 偺姰椆僴儞僪儔 (Invoke) 偱庴偗庢偭偨億僀儞僞偱偡丅
    If pController = 0 Then Exit Sub

    ' ICoreWebView2Controller::Close (Index 24) 傪幚峴
    ' 偙傟偵傛傝丄娭楢偡傞 msedgewebview2.exe 僾儘僙僗偑廔椆偟傑偡丅
    hr = DispCallFunc(pController, 24 * LenB(pController), CC_STDCALL, vbLong, 0, 0, 0, result)

    If hr = 0 Then
        Debug.Print "WebView2 Controller Closed."
    Else
        Debug.Print "Close Failed. HR: " & hr
    End If

    ' 億僀儞僞傪攋婞偟偰丄VBA懁偐傜傕嶲徠傪姰慡偵愗傞
    ' 偙傟傪朰傟傞偲丄VBA懁偑億僀儞僞傪乽埇偭偨傑傑乿偵側傝丄晄埨掕偵側傝傑偡丅
    Set WebView2 = Nothing '僆僽僕僃僋僩帺懱偺攋婞偵傛傝億僀儞僞傕徚偊傞丒丒丒偼偢
    pController = 0
    'pKeepEnv = 0
End Sub

