'嘇 僼僅乕僇僗偲偺楢摦
'put_IsVisible(True) 偵偡傞偲丄WebView2偼僉乕儃乕僪僼僅乕僇僗傪庴偗庢傟傞忬懺偵側傝傑偡丅媡偵 False 偵偡傞偲丄儅僂僗僀儀儞僩傗僉乕儃乕僪僀儀儞僩傪堦愗庴偗晅偗側偔側傝傑偡丅
'
'嘊 僂傿儞僪僂儊僢僙乕僕偺僴儞僪儕儞僌
'WebView2偼撪晹偱 WM_SHOWWINDOW 側偳偺儊僢僙乕僕傪偙偺儊僜僢僪宱桼偱張棟偟偰偄傑偡丅VBA偱 UserForm.Hide 側偳傪偟偨嵺丄WebView2懁偑乽帺暘傕塀傟偨乿偲惓偟偔擣幆偝偣傞偨傔偵偼丄杮棃偼偙偺儊僜僢僪傪 False 偵偡傞偺偑惓峌朄偱偡丅


' get_CoreWebView2 (Index 25) 愱梡丗億僀儞僞偺億僀儞僞傪搉偟偰幚懱傪庢摼
Public Function GetWebView2() As c3_WebView2

    Dim ppWebView2 As LongPtr
    Dim args(0) As Variant
    Dim argTypes(0) As Integer
    Dim argPtrs(0) As LongPtr
    
    Dim hr As Long
    Dim result As Variant

    ' 庴偗庢傝梡曄悢偺傾僪儗僗傪搉偡
    args(0) = VarPtr(ppWebView2)
    argTypes(0) = vbLongPtr ' 64bit側傜vbLongLong(20), 32bit側傜vbLong(3)
    argPtrs(0) = VarPtr(args(0))
 
    hr = DispCallFunc(pController, 25 * LenB(pController), CC_STDCALL, vbLong, 1, argTypes(0), argPtrs(0), result)
    If hr = 0 Then
    
        If result = 0 Then
        
            Dim WV2 As New c3_WebView2
            WV2.ppWebView2 = ppWebView2
            'Set GetWebView2 = WV2
            Set WebView2 = WV2
        
        Else
        
            Debug.Print "get_CoreWebView2偑幐攕偟傑偟偨丅result:", result
        
        End If
    
    Else
    
        Debug.Print "get_CoreWebView2傪幚峴偟傛偆偲偟傑偟偨偑丄偦傕偦傕DispCallFunc偑幐攕偟傑偟偨丅HR:", hr
    
    End If

End Function


