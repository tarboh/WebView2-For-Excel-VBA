'get_IsVisible(VtblIndex:3)
Public Property Get IsVisible() As Boolean

    Dim value As Long ' 栠傝抣乮BOOL乯傪庴偗庢傞曄悢
    Dim hr As Long     'DispCallFunc偺HRESULT
    Dim res As Variant 'put_IsVisible偺HRESULT
    
    ' 堷悢0: 抣傪彂偒崬傫偱傕傜偆偨傔偺乽曄悢value偺傾僪儗僗乿傪搉偡
    Dim vArgs(0) As Variant: vArgs(0) = VarPtr(value)
    Dim vTypes(0) As Integer: vTypes(0) = vbLongPtr
    Dim vPtrs(0) As LongPtr: vPtrs(0) = VarPtr(vArgs(0))
    
    ' Index 3: get_IsVisible 傪幚峴
    hr = DispCallFunc(pController, 3 * LenB(pController), CC_STDCALL, vbLong, 1, vTypes(0), vPtrs(0), res)
    
    If hr = 0 Then
        If res = 0 Then
            If value <> 0 Then
                IsVisible = True
            Else
                IsVisible = False
            End If
        Else
            '側傫偐僄儔乕揻偐偣傞
            Debug.Print "WebView2僆僽僕僃僋僩偺IsVisible僾儘僷僥傿偺庢摼偵幐攕偟傑偟偨丅"
        End If
    Else
        '抳柦揑幐攕
        Debug.Print "WebView2僆僽僕僃僋僩偺IsVisible僾儘僷僥傿傪庢摼偟傛偆偲偟傑偟偨偑丄偦傟埲慜偵DispCallFunc偑幐攕偟傑偟偨丅"
    End If

End Property

'put_IsVisible(VtblIndex:4)
Public Property Let IsVisible(value As Boolean)

    Dim hr As Long     'DispCallFunc偺HRESULT
    Dim res As Variant 'put_IsVisible偺HRESULT

    Dim vArgs(0) As Variant
    vArgs(0) = CLng(IIf(value, 1, 0))
    Dim vTypes(0) As Integer: vTypes(0) = vbLong
    Dim vPtrs(0) As LongPtr: vPtrs(0) = VarPtr(vArgs(0))
    hr = DispCallFunc(pController, 4 * LenB(pController), CC_STDCALL, vbLong, 1, vTypes(0), vPtrs(0), res)
    
    If hr = 0 Then
        If res = 0 Then
        Else
            Debug.Print "put_IsVisible Result: " & res
        End If
    Else
        '抳柦揑幐攕
        Debug.Print "WebView2僆僽僕僃僋僩偺IsVisible僾儘僷僥傿傪庢摼偟傛偆偲偟傑偟偨偑丄偦傟埲慜偵DispCallFunc偑幐攕偟傑偟偨丅"
    End If

End Property

'put_IsVisible 偺杮幙揑側栶妱
'偙偺儊僜僢僪偼丄WebView2偺乽恊僂傿儞僪僂乮UserForm摍乯偵懳偡傞昞帵忬懺偺僗僀僢僠乿偱偡丅
'
